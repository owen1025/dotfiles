#!/bin/bash
# uv-tool-packages hash: {{ include "uv-tool-packages.txt" | sha256sum }}
set -e
eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || /home/linuxbrew/.linuxbrew/bin/brew shellenv 2>/dev/null)" || true

command -v uv >/dev/null 2>&1 || { echo "uv not found — skipping uv tool installs" >&2; exit 0; }

while IFS= read -r line; do
	[ -z "$line" ] && continue
	case "$line" in \#*) continue ;; esac
	uv tool install $line
done < "{{ .chezmoi.sourceDir }}/uv-tool-packages.txt"
