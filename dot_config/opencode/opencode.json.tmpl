{
  "plugin": [
    "opencode-ntfy.sh@latest",
    "oh-my-openagent@latest"{{ if .useAnthropicAuth }},
    "@ex-machina/opencode-anthropic-auth@latest"{{ end }}
  ],
  "mcp": {
    "kubernetes": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-kubernetes"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "slack": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@zencoderai/slack-mcp-server"
      ],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true
    },
    "linear": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@tacticlaunch/mcp-linear"
      ],
      "enabled": true
    },
    "notion": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@notionhq/notion-mcp-server@1.9.1"
      ],
      "enabled": true
    },
    "gdrive": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@isaacphi/mcp-gdrive"
      ],
      "environment": {
        "CLIENT_ID": "{env:GDRIVE_CLIENT_ID}",
        "CLIENT_SECRET": "{env:GDRIVE_CLIENT_SECRET}",
        "GDRIVE_CREDS_DIR": "{env:HOME}/.config/gdrive-mcp"
      },
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "enabled": true
    },
    "terraform": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "terraform-mcp-server"
      ],
      "enabled": true
    },
    "gcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-gcp"
      ],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-fetch"
      ],
      "enabled": true
    },
    "git": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-git"
      ],
      "enabled": true
    },
    "time": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-time",
        "--local-timezone",
        "Asia/Seoul"
      ],
      "enabled": true
    },
    "depwire": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "depwire-cli",
        "mcp"
      ],
      "enabled": true
    },
    "mcp-registry": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@mcpfinder/server"
      ],
      "enabled": true
    },
    "pulsemcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "pulsemcp-server"
      ],
      "enabled": true
    },
    "glama": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-glama-registry"
      ],
      "enabled": true
    }
  },
  "provider": {
    "openai": {
      "name": "OpenAI",
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5",
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        },
        "gpt-5.5-mini": {
          "name": "GPT-5.5 Mini",
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 32768
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (Local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "batiai/qwen3.6-35b:iq4": {
          "name": "Qwen 3.6 35B-A3B (BatiAI IQ4, local)",
          "tools": true,
          "reasoning": true,
          "limit": {
            "context": 32768,
            "output": 4096
          }
        }
      }
    }
  },
  "$schema": "https://opencode.ai/config.json"
}
