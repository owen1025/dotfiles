{
  "plugin": [
    "opencode-ntfy.sh@latest",
    "oh-my-openagent@latest",
{{- if .useAnthropicAuth }}
    "@ex-machina/opencode-anthropic-auth@latest",
{{- end }}
    "opencode-antigravity-auth@latest"
  ],
  "mcp": {
    "kubernetes": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-kubernetes"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "slack": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "slack-mcp-server",
        "--transport",
        "stdio"
      ],
      "environment": {
        "SLACK_MCP_XOXC_TOKEN": "${SLACK_MCP_XOXC_TOKEN}",
        "SLACK_MCP_XOXD_TOKEN": "${SLACK_MCP_XOXD_TOKEN}"
      },
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true
    },
    "linear": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@tacticlaunch/mcp-linear"
      ],
      "enabled": true
    },
    "notion": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@notionhq/notion-mcp-server@1.9.1"
      ],
      "enabled": true
    },
    "gdrive": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@isaacphi/mcp-gdrive"
      ],
      "environment": {
        "CLIENT_ID": "${GDRIVE_CLIENT_ID}",
        "CLIENT_SECRET": "${GDRIVE_CLIENT_SECRET}",
        "GDRIVE_CREDS_DIR": "${HOME}/.config/gdrive-mcp"
      },
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@ldraney/github-mcp"
      ],
      "environment": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "enabled": true
    },
    "terraform": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "terraform-mcp-server"
      ],
      "enabled": true
    },
    "gcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-gcp"
      ],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-fetch"
      ],
      "enabled": true
    },
    "git": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-git"
      ],
      "enabled": true
    },
    "time": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-time",
        "--local-timezone",
        "Asia/Seoul"
      ],
      "enabled": true
    },
    "depwire": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "depwire-cli",
        "mcp"
      ],
      "enabled": true
    },
    "mcp-registry": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@mcpfinder/server"
      ],
      "enabled": true
    },
    "pulsemcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "pulsemcp-server"
      ],
      "enabled": true
    },
    "glama": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-glama-registry"
      ],
      "enabled": true
    }
  },
  "provider": {
    "google": {
      "name": "Google",
      "models": {
        "antigravity-gemini-3-pro-high": {
          "name": "Gemini 3 Pro High (Antigravity)",
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        },
        "antigravity-gemini-3-pro-low": {
          "name": "Gemini 3 Pro Low (Antigravity)",
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        },
        "antigravity-gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "openai": {
      "name": "OpenAI",
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5",
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        },
        "gpt-5.5-mini": {
          "name": "GPT-5.5 Mini",
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 32768
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "$schema": "https://opencode.ai/config.json"
}
