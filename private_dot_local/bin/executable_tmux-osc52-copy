#!/bin/sh
# tmux-osc52-copy: Send data to clipboard via OSC 52 written directly
# to the active tmux client's outer TTY (mosh-compatible, no tmux passthrough).
#
# Why not pane_tty + DCS passthrough?
#   tmux strips the DCS wrap and forwards the inner OSC 52 to ITS controlling
#   terminal — which for a mosh session is the mosh-server's internal pty,
#   not the pty that mosh forwards to the client. Result: OSC 52 is
#   consumed server-side and never reaches the client's outer terminal.
#   Empirically reproduced on tmux 3.6a + mosh 1.4.0 + Ghostty.
#   See: https://github.com/mobile-shell/mosh/pull/1104 (delbao comment, 2022)
#
# Why client_tty works:
#   Each attached tmux client has its own slave pty (#{client_tty}) which
#   is the *outer* terminal as tmux sees it. For a mosh client that pty is
#   owned by the mosh-server process — writing OSC 52 there goes straight
#   through UDP to the mosh-client and into Ghostty's clipboard. No tmux
#   passthrough / DCS wrap needed. Works identically for local Ghostty.
#
# Data source:
#   - If stdin is a pipe/redirect with actual data: read from stdin
#     → enables `cat file | tmux-osc52-copy`, `echo foo | tmux-osc52-copy`, etc.
#   - Otherwise (empty stdin, tty, or `run-shell -b`): read from tmux buffer
#     → preserves tmux copy-mode binding (run-shell -b 'tmux-osc52-copy')
#
# IMPORTANT: `tmux run-shell -b` spawns the subprocess with stdin = non-TTY
# AND empty (not a real pipe). So `[ ! -t 0 ]` alone cannot distinguish
# "real pipe with data" from "run-shell empty stdin" — we must also check
# whether `cat` returned anything, and fall through to `save-buffer` if not.
# Without this fallthrough, the keybinding path emits an EMPTY OSC 52,
# which clobbers the clipboard with "". Confirmed on tmux 3.6a.
set -eu

raw=''
if [ ! -t 0 ]; then
  raw=$(cat)
fi
if [ -z "$raw" ]; then
  raw=$(tmux save-buffer - 2>/dev/null || printf '')
fi

# Nothing to copy — abort without clobbering the clipboard.
[ -n "$raw" ] || exit 0

# mosh 1.4.0 requires 'c;' selection prefix; also accepted by Ghostty/xterm.
buf=$(printf '%s' "$raw" | base64 | tr -d '\r\n')

# Find the most-recently-active client attached to this pane's session.
# #{client_activity} is a Unix timestamp — higher means more recent keyboard
# activity, which reliably identifies the user's foreground session even
# when multiple clients are attached (stale ssh, headless mosh-server, ...).
session=$(tmux display-message -p '#{session_name}' 2>/dev/null || printf '')
target_tty=''
if [ -n "$session" ]; then
  target_tty=$(tmux list-clients -t "$session" \
    -F '#{client_activity} #{client_tty}' 2>/dev/null \
    | sort -rn | head -n1 | awk '{print $2}')
fi

# Write OSC 52 directly to the client's outer tty.
# Ghostty receives it (clipboard-write = allow) and updates the macOS pasteboard.
if [ -n "$target_tty" ] && [ -w "$target_tty" ]; then
  printf '\033]52;c;%s\007' "$buf" > "$target_tty" 2>/dev/null || true
fi

# Also set local macOS clipboard for direct (non-mosh, non-ssh) tmux sessions.
# No-op on Linux (pbcopy absent).
command -v pbcopy >/dev/null 2>&1 && printf '%s' "$raw" | pbcopy 2>/dev/null || true
