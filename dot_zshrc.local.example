# Machine-specific environment variables (secrets only)
# Copy this file to ~/.zshrc.local and fill in your values:
#   cp ~/.zshrc.local.example ~/.zshrc.local

# === Credentials ===
export NOTION_API_KEY=""
export NOTION_TOKEN=""
export LINEAR_API_TOKEN=""
export SLACK_MCP_XOXC_TOKEN=""
export SLACK_MCP_XOXD_TOKEN=""
export NTFY_TOPIC=""
export PLAYWRIGHT_MCP_EXTENSION_TOKEN=""

# === GitHub (reuse gh CLI OAuth token for MCP/opencode) ===
# Requires: gh auth login (one-time)
export GITHUB_TOKEN="$(gh auth token 2>/dev/null)"

# === Slack Bot Factory (auto-managed by slack-bot-factory skill) ===
# Format: SLACK_{WORKSPACE}_{BOT}_{APP_TOKEN|BOT_TOKEN}
# Example:
#   export SLACK_NOANSWER_SECRETARY_APP_TOKEN="xapp-..."
#   export SLACK_NOANSWER_SECRETARY_BOT_TOKEN="xoxb-..."
