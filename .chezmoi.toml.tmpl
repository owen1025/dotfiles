{{- $email := promptStringOnce . "email" "Git email address" -}}
{{- $name := promptStringOnce . "name" "Git full name" -}}
{{- $useAnthropicAuth := promptBoolOnce . "useAnthropicAuth" "Use Anthropic auth plugin for OpenCode (not Claude Code CLI)" -}}

[data]
    email = {{ $email | quote }}
    name = {{ $name | quote }}
    useAnthropicAuth = {{ $useAnthropicAuth }}
