#!/bin/bash
# Auto-generated by slack-opencode-bridge-factory
# DO NOT EDIT — regenerate with: omo-bridge update {{AGENT_NAME}}

# Load secrets from ~/.zshrc.local
set +e
source "${HOME}/.zshrc.local" 2>/dev/null
set -e

# Load agent-specific env vars
