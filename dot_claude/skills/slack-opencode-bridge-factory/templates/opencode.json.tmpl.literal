{
  "$schema": "https://opencode.ai/config.json",
  "model": "{{MODEL}}",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "{{MODEL}}",
      "prompt": "{file:./AGENTS.md}"
    }
  },
  "mcp": {
    "scheduler": {
      "type": "local",
      "command": [
        "{{PYTHON_BIN}}",
        "{{PROJECT_DIR}}/bridge/scheduler_mcp.py"
      ],
      "enabled": true,
      "environment": {
        "AGENT_NAME": "{{AGENT_NAME}}",
        "SCHEDULE_TIMEZONE": "Asia/Seoul",
        "BRIDGE_CONFIG_DIR": "{{HOME_DIR}}/.config/opencode-bridges"
      }
    }
  }
}
